{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shadow",
  "version": "0.1.0",
  "identifier": "com.sanket.shadow",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Shadow",
        "resizable": true,
        "minWidth": 1280,
        "minHeight": 720,
        "width": 1500,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/shadow.png", "icons/shadow.ico"],
    "shortDescription": "Shadow Protocol Desktop App",
    "longDescription": "Shadow Protocol - Desktop application",
    "category": "DeveloperTool",
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "resources": []
  }
}
